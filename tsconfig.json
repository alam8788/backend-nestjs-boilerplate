{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "target": "es2022",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "plugins": [
      {
        "name": "@nestjs/swagger/plugin"
      }
    ]
  },
  "exclude": [
    "node_modules",
    "dist",
    "logs",
    "uploads/",
    ".prisma",
    "data/streaming-assets/**/*",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
